# Public hostname for the primary site.
DOMAIN=amythical.crabdance.com

# Only set this when using a secondary A record for FreeDNS web redirect
# because your ISP blocks the standard external port.
SECDOMAIN=

# FreeDNS dynamic update endpoint. Leave blank to disable containerized updates.
UPDATE_URL=https://freedns.afraid.org/dynamic/update.php?your_token_here

# Caddy defaults to plain HTTP behind another reverse proxy. Switch to direct
# HTTPS mode by setting BEHIND_PROXY=false and GET_HTTPS_CERTIFICATE=true.
EXTERIOR_PORT=38380
EXTERIOR_PORT_HTTPS=443

# Reverse-proxy/TLS behavior.
BEHIND_PROXY=true
GET_HTTPS_CERTIFICATE=false

# Media/runtime toggles.
MUSIC_DIRECTORY=./music
USE_SNAPCAST=true
USE_AVAHI=true
AVAHI_PUBLISHED_PORT=5353
STREAM_OUT=true

# Additional service ports exposed from the app container.
MPD_CONTROL_PORT=6600
MINIDLNA_PORT=8200
MINIDLNA_DISCOVERY_PORT=1900
SNAPCAST_STREAM_PORT=1704
SNAPCAST_CONTROL_PORT=1705
SNAPWEB_PORT=1780
